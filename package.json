{
  "name": "x-telegram-monitor",
  "version": "1.0.0",
  "description": "Self-hosted X account monitor with Telegram forwarding and Russian translation",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/src/index.js",
    "debug:fetch": "tsx scripts/debug-fetch.ts",
    "debug:translate": "tsx scripts/debug-translate.ts",
    "x:init-session": "tsx scripts/init-x-session.ts",
    "x:capture-session": "tsx scripts/capture-x-session-cdp.ts",
    "test": "npm run build && node dist/tests/run-tests.js",
    "check": "npm run test"
  },
  "keywords": [
    "x",
    "twitter",
    "telegram",
    "sqlite",
    "monitoring",
    "ctranslate2"
  ],
  "author": "local",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "dotenv": "^17.4.1",
    "pino": "^10.3.1",
    "playwright-core": "^1.59.1",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
