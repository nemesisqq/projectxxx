TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

POLL_INTERVAL_SECONDS=45
X_ACCOUNTS=bcherny,karpathy
INCLUDE_REPOSTS=true
INCLUDE_QUOTES=true
INCLUDE_REPLIES=false

SEND_ORIGINAL_TEXT=true
SEND_TRANSLATION=true
LOG_LEVEL=info
DRY_RUN=false

SQLITE_PATH=./data/state.db
X_PROVIDER=playwright
X_FETCH_LIMIT=20
X_BOOTSTRAP_LIMIT=20

X_BROWSER_CHANNEL=msedge
X_BROWSER_EXECUTABLE_PATH=
X_STORAGE_STATE_PATH=./data/x-storage-state.json
X_HEADLESS=true
X_CDP_URL=http://127.0.0.1:9222
X_NAVIGATION_TIMEOUT_MS=45000
X_FETCH_TIMEOUT_MS=12000

X_API_BEARER_TOKEN=
X_API_BASE_URL=https://api.x.com
X_API_TIMEOUT_MS=15000
X_API_RETRIES=2
X_API_RETRY_DELAY_MS=1000

TELEGRAM_MAX_RETRIES=4
TELEGRAM_RETRY_DELAY_MS=1500

TRANSLATION_ENABLED=true
TRANSLATION_PROVIDER=ctranslate2
TRANSLATION_MODEL_PATH=./models/ct2-opus-en-ru
TRANSLATION_TOKENIZER_PATH=./models/ct2-opus-en-ru
TRANSLATION_SOURCE_LANG=en
TRANSLATION_TARGET_LANG=ru
TRANSLATION_TIMEOUT_MS=12000
TRANSLATION_RETRIES=2
TRANSLATION_RETRY_DELAY_MS=500
TRANSLATION_SKIP_IF_RUSSIAN=true

TRANSLATION_SERVICE_URL=http://127.0.0.1:8765
TRANSLATION_PYTHON_BIN=python
TRANSLATION_AUTO_START=true
TRANSLATION_STARTUP_TIMEOUT_MS=15000
TRANSLATION_SERVICE_SCRIPT_PATH=./translator/ctranslate2_service.py
